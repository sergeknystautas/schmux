#!/bin/bash
set -e

cd "$(git rev-parse --show-toplevel)"

# Get staged files
GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
PRETTIER_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|css|md|json)$' || true)

# Capture which files are partially staged BEFORE formatting.
# These are the only files we must skip re-staging — formatting + git add would
# silently include their unstaged changes.
PARTIALLY_STAGED=""
for f in $GO_FILES $PRETTIER_FILES; do
    if git diff --name-only -- "$f" | grep -q .; then
        PARTIALLY_STAGED="$PARTIALLY_STAGED"$'\n'"$f"
    fi
done

if [ -n "$PARTIALLY_STAGED" ]; then
    echo "Warning: the following files are partially staged:"
    echo "$PARTIALLY_STAGED" | sed '/^$/d' | sed 's/^/  /'
    echo "Formatting will only re-stage files with no unstaged changes."
    echo "Partially staged files will be formatted on disk but NOT re-staged."
fi

# Helper: returns 0 if file was partially staged before formatting
was_partially_staged() {
    echo "$PARTIALLY_STAGED" | grep -qxF "$1"
}

# Ensure prettier is available (only if we have prettier-eligible files)
if [ -n "$PRETTIER_FILES" ]; then
    if ! (cd assets/dashboard && npm list prettier >/dev/null 2>&1); then
        echo "Installing prettier..."
        (cd assets/dashboard && npm install --save-dev prettier)
    fi
fi

# Format Go files
if [ -n "$GO_FILES" ]; then
    echo "Formatting Go files..."
    echo "$GO_FILES" | xargs gofmt -w
    for f in $GO_FILES; do
        if ! was_partially_staged "$f"; then
            git add "$f"
        fi
    done
fi

# Format Prettier files
if [ -n "$PRETTIER_FILES" ]; then
    echo "Formatting TS/JS/CSS/MD/JSON files..."
    echo "$PRETTIER_FILES" | xargs npx --prefix assets/dashboard prettier --write --ignore-unknown
    for f in $PRETTIER_FILES; do
        if ! was_partially_staged "$f"; then
            git add "$f"
        fi
    done
fi
